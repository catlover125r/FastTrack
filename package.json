{
  "name": "fasttrack",
  "productName": "FastTrack",
  "version": "1.0.0",
  "description": "A stripped-down, Logic-styled audio editor for quick edits",
  "main": "main.js",
  "author": "catlover125r",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.catlover125r.fasttrack",
    "productName": "FastTrack",
    "mac": {
      "category": "public.app-category.music",
      "identity": null
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/soundtouchjs/**/*",
      "node_modules/@breezystack/lamejs/**/*"
    ]
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "soundtouchjs": "^0.3.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0"
  },
  "allowScripts": {
    "@breezystack/lamejs@1.2.7": true,
    "electron@43.0.0": true
  }
}
